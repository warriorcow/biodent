mixin header(lists, navigations, without_logo)
    header.header(class=without_logo?'without_logo':'')
        .header__mobile
            a.header__logo(href='/')
                svg
                    use(href='img/sprites/sprite.svg#biodent')
            button.header__hamburger
        .header__desktop
            .header__close
            .header__mobile-menu-wrapper
                .container
                    +button({
                      text: 'Записаться на прием',
                      tag: 'button',
                      theme: 'transparent',
                      modal: 'callback'
                    }).header__mobile-button
                .header__container
                    .container
                        .header__list
                            each list in lists
                                if list.phones
                                    .header__list-item.header__list-item--phones
                                        each phone in list.phones
                                            a.header__list-phone(href=`tel:${phone.text}`)
                                                if phone.icon
                                                    svg.header__list-icon
                                                        use(href=phone.icon)
                                                != phone.text
                                else if list.socials
                                    .header__list-item.header__list-item--socials
                                        each social in list.socials
                                            a.header__social(href=social.link target='_blank' rel='noopener noreferrer')
                                                svg.header__social-icon
                                                    use(href=social.icon)
                                else if list.icon
                                    .header__list-item
                                        svg.header__list-icon
                                            use(href=list.icon)
                                        | #{list.text}
                                else
                                    .header__list-item= list.text
                .header__container.header__container--navigation
                    .container
                        nav.header__navigation
                            a.header__logo(href='/')
                                svg
                                    use(href='img/sprites/sprite.svg#biodent')
                            ul.header__navigation-list
                                each navigation in navigations
                                    li.header__navigation-item(class=navigation.nested ? 'header__navigation-item--with-list':'')
                                        a(href=navigation.link).header__navigation-name= navigation.name
                                        if navigation.nested
                                            .header__navigation-submenu
                                                ul.header__navigation-submenu-wrapper
                                                    each subname in navigation.nested
                                                        li.header__navigation-subname
                                                            a(href=subname.link).header__navigation-sublink= subname.name
                            +button({
                              text: 'Записаться на прием',
                              theme: 'transparent',
                              modal: 'callback',
                              tag: 'button'
                            }).header__button

